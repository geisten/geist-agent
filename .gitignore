# Build outputs from new make-based build system (Phase A).
# Per-target, per-mode segregated.
build/
lib/
bin/
deps/geist/

# Python
__pycache__/
*.py[cod]
*$py.class

# Local OS/editor/agent state
.DS_Store
.clangd
.claude/

# Binaries im Root (vom Makefile gebaut)
eval_geist
profile_decode
dump_llamacpp_logits
bench_sgemv
/test_*

# Local model and conversion artifacts. These are large, reproducible, or
# machine-specific and should not enter git.
